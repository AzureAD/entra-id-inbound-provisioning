# Server
PORT=3001

# Entra ID / Azure AD Configuration
#
# ⚠️  SENSITIVE SECRETS — TENANT_ID/CLIENT_ID are identifiers and CLIENT_SECRET is a
#     credential. The PROVISIONING_API_ENDPOINT identifies your job. This `.env` file is
#     gitignored and must NEVER be committed. Preferred approach: leave these unset and
#     enter the values in the UI instead, where they are held in memory only and never
#     written to disk. The lines below are commented out so persisting secrets is opt-in.
# TENANT_ID=your-tenant-id
# CLIENT_ID=your-client-id
# CLIENT_SECRET=your-client-secret

# Provisioning API Endpoint (from Entra admin center > Provisioning > Overview > Provisioning API Endpoint)
# PROVISIONING_API_ENDPOINT=https://graph.microsoft.com/beta/servicePrincipals/{servicePrincipalId}/synchronization/jobs/{jobId}/bulkUpload
